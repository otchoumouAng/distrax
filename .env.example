# Bascule rapide : dev ou prod
# - dev  → charge .env.dev (proxy /api, CORS souple)
# - prod → charge .env.prod (API dystrax.com)
# Utilisé par : npm run dev, npm run build
ENV=dev

# Les variables réelles (VITE_API_URL…) sont dans .env.dev et .env.prod
# Copiez .env.dev et .env.prod depuis ce repo et adaptez-les.
